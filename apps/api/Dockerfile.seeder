# Seeder image — sama source seperti api, tapi jalankan `go run ./cmd/seed`
# untuk migrate + seed. Dipakai sebagai one-shot service di docker-compose.
FROM golang:1.22-alpine

RUN apk add --no-cache git
WORKDIR /app

COPY go.mod go.sum* ./
RUN go mod download || true

COPY . .

ENV DATABASE_URL=postgres://ticketing:ticketing_secret@postgres:5432/ticketing?sslmode=disable
ENV REDIS_URL=redis://redis:6379

CMD ["go", "run", "./cmd/seed"]
