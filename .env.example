# ============================================
# Aplikasi
# ============================================
APP_ENV=development
SITE_NAME="War Tiket"

# ============================================
# API (Go backend)
# ============================================
API_PORT=8080
API_BASE_URL=http://localhost:8080

# ============================================
# Web (Nuxt frontend)
# ============================================
WEB_PORT=3000

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing_secret
POSTGRES_DB=ticketing
POSTGRES_PORT=5432
DATABASE_URL=postgres://ticketing:ticketing_secret@localhost:5432/ticketing?sslmode=disable

# ============================================
# Redis
# ============================================
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ============================================
# JWT
# ============================================
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_HOURS=24

# ============================================
# Business Config
# ============================================
# Booking soft-reservation TTL (menit)
BOOKING_TTL_MINUTES=10
# Queue session token TTL (menit)
QUEUE_SESSION_TTL_MINUTES=5
# War queue: max join requests per user per menit
WAR_RATE_LIMIT_PER_MIN=5

# ============================================
# Payment (simulasi)
# ============================================
PAYMENT_MODE=simulation
# Akan diisi jika integrasi real payment gateway
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
